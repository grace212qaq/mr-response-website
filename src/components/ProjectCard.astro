---
export interface Props {
  title: string;
  description: string;
  tags?: string[];
  href: string;
}

const { title, description, tags, href } = Astro.props;
---

<a href={href} class="project-card">
  <h3>{title} →</h3>
  <p>{description}</p>
  {tags && tags.length > 0 && (
    <div class="tags">
      {tags.map(t => <span class="tag">{t}</span>)}
    </div>
  )}
</a>
